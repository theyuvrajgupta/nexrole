# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase project settings (Project Settings > API Keys in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
# "Publishable key" (sb_publishable_...) - safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# "Secret key" (sb_secret_...) - server-only, bypasses RLS. Used solely for admin
# operations that must run before a user has a session. Never expose to the client.
SUPABASE_SECRET_KEY=

# Anthropic API key. Server-only — never referenced from client code.
ANTHROPIC_API_KEY=
# Model id, kept as config so it can move without a code change.
ANTHROPIC_MODEL=claude-sonnet-4-5

# Base URL of the deployed app, used to build the magic-link redirect target.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
